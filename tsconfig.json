{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules"]
}
